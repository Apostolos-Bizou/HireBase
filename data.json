      {"from":"nikos","text":"Hello, I need 2 more housekeepers for the summer season. Can you help?","time":"Mar 18, 10:30"},
      {"from":"admin","text":"Hi Nikos! Absolutely. We have 8 ready housekeepers in our pool. I'll send you a shortlist by tomorrow.","time":"Mar 18, 11:15"},
      {"from":"nikos","text":"That would be great. We need them by May at the latest.","time":"Mar 18, 11:20"},
      {"from":"nikos","text":"Also, can you include candidates with hotel experience specifically?","time":"Mar 18, 11:22"}
    ]},
    {"id":2,"name":"Maria Reyes","role":"Housekeeper · Deployed","avatar":"MR","unread":0,"msgs":[
      {"from":"maria","text":"Hi, I arrived in Athens safely. The hotel staff was very welcoming!","time":"Mar 1, 18:00"},
      {"from":"admin","text":"Welcome to Greece, Maria! So glad to hear that. How is the accommodation?","time":"Mar 1, 18:30"},
      {"from":"maria","text":"Very good, thank you. The room is nice and close to work.","time":"Mar 1, 19:00"},
      {"from":"admin","text":"Perfect. Remember, we're here if you need anything. Your 90-day check-in is scheduled for May 30.","time":"Mar 2, 09:00"}
    ]},
    {"id":3,"name":"Elena Petridou","role":"Thessaloniki Care · Employer","avatar":"EP","unread":1,"msgs":[
      {"from":"elena","text":"When can we expect Anna Lim's interview to be completed?","time":"Mar 15, 14:00"},
      {"from":"admin","text":"The video interview is scheduled for March 18. You'll receive the recording and evaluation within 24 hours after.","time":"Mar 15, 14:45"},
      {"from":"elena","text":"Perfect. We really need her to start by June.","time":"Mar 17, 09:00"}
    ]},
    {"id":4,"name":"Jose Cruz","role":"Line Cook · Visa Pending","avatar":"JC","unread":0,"msgs":[
      {"from":"jose","text":"Any update on my visa application?","time":"Mar 12, 10:00"},
      {"from":"admin","text":"Hi Jose, your Type D visa was submitted to the Greek Consulate on March 5. Typical processing is 2-4 weeks. We'll update you as soon as we hear back.","time":"Mar 12, 10:30"},
      {"from":"jose","text":"Thank you. I'm very excited about this opportunity!","time":"Mar 12, 11:00"}
    ]}
